MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=465
MAIL_USERNAME=system@example.com
MAIL_PASSWORD=change-me
MAIL_ENCRYPTION=SSL
MAIL_FROM_ADDRESS=system@example.com
MAIL_FROM_NAME=Stock Flow Manager
NEXT_PUBLIC_APP_URL=https://your-vercel-app.vercel.app

# MySQL. Encode special characters in the database name; CPAC_SB&M becomes CPAC_SB%26M.
DATABASE_URL=mysql://username:password@192.168.1.196:3306/CPAC_SB%26M

# RMC SSO (server-only; never prefix secrets with NEXT_PUBLIC_)
SSO_ISSUER=https://rmc-sso.cipcloud.net
SSO_CLIENT_ID=cpac_sb-m
SSO_CLIENT_SECRET=replace-with-client-secret
SSO_AUTHORIZE_URL=https://rmc-sso.cipcloud.net/api/auth/oauth2/authorize
SSO_TOKEN_URL=https://rmc-sso.cipcloud.net/api/auth/oauth2/token
SSO_USERINFO_URL=https://rmc-sso.cipcloud.net/api/auth/oauth2/userinfo
SSO_END_SESSION_URL=https://rmc-sso.cipcloud.net/api/auth/oauth2/endsession
SSO_REDIRECT_URI=http://localhost:3000/api/auth/callback/rmc-sso
SSO_POST_LOGOUT_REDIRECT_URI=http://localhost:3000/signed-out
SSO_SCOPE=openid profile email offline_access
APP_SESSION_SECRET=generate-a-separate-long-random-secret
